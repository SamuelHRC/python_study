   "source": [
    "# Traduzindo o pseudocódigo para Python\n",
    "nota1 = 7.5\n",
    "nota2 = 8.0\n",
    "\n",
    "media = (nota1 + nota2) / 2\n",
    "\n",
    "print(f\"A média do aluno é: {media}\")\n",
    "\n",
    "if media >= 7.0:\n",
    "    print(\"Aluno aprovado!\")\n",
    "else:\n",
    "    print(\"Aluno reprovado.\")"
   ]
